---
/**
 * Header component — Logo, language selector, theme switcher
 */
---

<header class="header">
  <div class="header-left">
    <span class="logo-icon">◆</span>
    <span class="logo-text">
      <span class="logo-title" data-i18n="app.title">TeeForge</span>
      <span class="logo-sub" data-i18n="app.subtitle">Integrity Toolkit</span>
    </span>
  </div>

  <div class="header-right">
    <select class="header-select" id="lang-select" aria-label="Language">
      <option value="auto">Auto</option>
      <option value="en">EN</option>
      <option value="zh">中文</option>
      <option value="ja">日本語</option>
    </select>

    <select class="header-select" id="theme-select" aria-label="Theme">
      <option value="material:auto">Auto</option>
      <option value="material:light">Light</option>
      <option value="material:dark">Dark</option>
    </select>
  </div>
</header>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0 8px;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    font-size: 1.4rem;
    color: var(--color-accent);
    filter: drop-shadow(0 0 6px var(--color-accent));
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-title {
    font-weight: 700;
    font-size: 1.05rem;
  }

  .logo-sub {
    font-size: 0.7rem;
    color: var(--color-fg-muted);
    letter-spacing: 0.03em;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-select {
    font-family: inherit;
    font-size: 0.75rem;
    padding: 4px 8px;
    border-radius: var(--radius-xs);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-fg);
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .header-select:hover {
    border-color: var(--color-border-hover);
  }

  .header-select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
</style>

<script>
  function initHeader() {
    const langSelect = document.getElementById('lang-select') as HTMLSelectElement;
    const themeSelect = document.getElementById('theme-select') as HTMLSelectElement;

    // Sync language selector with current state
    if (langSelect) {
      const savedLang = localStorage.getItem('tf-lang');
      langSelect.value = savedLang || 'auto';

      langSelect.addEventListener('change', () => {
        if (langSelect.value === 'auto') {
          localStorage.removeItem('tf-lang');
        } else {
          localStorage.setItem('tf-lang', langSelect.value);
        }
        // Re-init i18n to pick up change
        window.__tf.refreshI18n();
      });

      // Listen for i18n updates to sync selector label
      // (e.g., after refreshI18n completes, update the "Auto" label to show detected lang)
      const observer = new MutationObserver(() => {
        const detected = window.__tf.getLang();
        const autoOpt = langSelect.querySelector('option[value="auto"]');
        if (autoOpt && !savedLang) {
          autoOpt.textContent = 'Auto (' + detected.toUpperCase() + ')';
        }
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
    }

    // Sync theme selector
    if (themeSelect) {
      const current = window.__tf.getTheme() + ':' + window.__tf.getMode();
      themeSelect.value = current;
      themeSelect.addEventListener('change', () => {
        const [theme, mode] = themeSelect.value.split(':');
        window.__tf.setTheme(theme, mode);
      });
    }
  }

  // Run after i18n has initialized
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => setTimeout(initHeader, 150));
  } else {
    setTimeout(initHeader, 150);
  }
</script>
