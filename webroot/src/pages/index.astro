---
/**
 * TeeForge WebUI — Main Page
 * Composes Header, StatusCard, ActionCards, LogDialog
 * Handles command execution via ksu.exec() with cwd option
 */
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import StatusCard from '../components/StatusCard.astro';
import ActionCard from '../components/ActionCard.astro';
import LogDialog from '../components/LogDialog.astro';
---

<Base>
  <Header />
  <StatusCard />

  <ActionCard
    id="btn-keybox"
    icon="🔑"
    titleKey="action.keybox.title"
    descKey="action.keybox.desc"
    action="keybox"
  />

  <ActionCard
    id="btn-target"
    icon="📋"
    titleKey="action.target.title"
    descKey="action.target.desc"
    action="target"
  />

  <LogDialog />
</Base>

<script>
  const MODDIR = '/data/adb/modules/teeforge_cd';
  const TEEFORGE = MODDIR + '/teeforge';
  // Pass cwd so teeforge finds ./sys.conf and ./config.conf in its module dir
  const EXEC_OPTS = JSON.stringify({ cwd: MODDIR });

  /**
   * ksu.exec with cwd — callback pattern
   * ksu.exec(cmd, optionsJson, callbackName)
   * callback receives (exitCode, stdout, stderr)
   */
  function execCmd(cmd: string): Promise<{ code: number; stdout: string; stderr: string }> {
    return new Promise((resolve) => {
      const cb = 'cb_' + Date.now() + '_' + (Math.random() * 10000 | 0);
      (window as any)[cb] = (code: number, stdout: string, stderr: string) => {
        delete (window as any)[cb];
        resolve({ code, stdout: stdout || '', stderr: stderr || '' });
      };
      ksu.exec(cmd, EXEC_OPTS, cb);
    });
  }

  function disableButtons() {
    document.querySelectorAll('.action-btn').forEach((b) => {
      (b as HTMLButtonElement).disabled = true;
      const spinner = b.querySelector('.spinner') as HTMLElement;
      const text = b.querySelector('.btn-text') as HTMLElement;
      if (spinner) spinner.style.display = 'inline-block';
      if (text) text.style.opacity = '0.6';
    });
  }

  function reenableButtons() {
    document.querySelectorAll('.action-btn').forEach((b) => {
      (b as HTMLButtonElement).disabled = false;
      const spinner = b.querySelector('.spinner') as HTMLElement;
      const text = b.querySelector('.btn-text') as HTMLElement;
      if (spinner) spinner.style.display = 'none';
      if (text) text.style.opacity = '1';
    });
  }

  async function runAction(flag: string, titleKey: string) {
    const dialog = (window as any).__tfDialog;
    const t = (window as any).__tf.t;

    disableButtons();
    dialog.open(t(titleKey));

    // Try spawn first for streaming output, fallback to exec
    if (typeof ksu.spawn === 'function') {
      try {
        const child = ksu.spawn(TEEFORGE + ' ' + flag, { cwd: MODDIR });
        child.stdout.on('data', (chunk: string) => dialog.appendLog(chunk));
        child.stderr.on('data', (chunk: string) => dialog.appendLog(chunk));
        child.on('exit', (code: number) => {
          dialog.done(code === 0, code);
          reenableButtons();
        });
        child.on('error', (err: any) => {
          dialog.appendLog('\n[spawn error] ' + String(err));
          dialog.done(false, -1);
          reenableButtons();
        });
        return;
      } catch (_) {
        // spawn not available, fall through to exec
      }
    }

    // Fallback: exec (output all at once after command finishes)
    try {
      const result = await execCmd(TEEFORGE + ' ' + flag);
      if (result.stdout) dialog.appendLog(result.stdout);
      if (result.stderr) dialog.appendLog(result.stderr);
      dialog.done(result.code === 0, result.code);
    } catch (err) {
      dialog.appendLog('\n[error] ' + String(err));
      dialog.done(false, -1);
    }

    reenableButtons();
  }

  document.getElementById('btn-keybox')?.addEventListener('click', () => {
    runAction('--keybox', 'action.keybox.title');
  });

  document.getElementById('btn-target')?.addEventListener('click', () => {
    runAction('--generate', 'action.target.title');
  });
</script>
