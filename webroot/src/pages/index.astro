---
/**
 * TeeForge WebUI — Main Page
 * Composes Header, StatusCard, ActionCards, LogDialog
 * Handles command execution via ksu.exec()
 */
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import StatusCard from '../components/StatusCard.astro';
import ActionCard from '../components/ActionCard.astro';
import LogDialog from '../components/LogDialog.astro';
---

<Base>
  <Header />
  <StatusCard />

  <ActionCard
    id="btn-keybox"
    icon="🔑"
    titleKey="action.keybox.title"
    descKey="action.keybox.desc"
    action="keybox"
  />

  <ActionCard
    id="btn-target"
    icon="📋"
    titleKey="action.target.title"
    descKey="action.target.desc"
    action="target"
  />

  <LogDialog />
</Base>

<script>
  const TEEFORGE = '/data/adb/modules/teeforge_cd/teeforge';

  /**
   * Execute command via ksu.exec (callback pattern)
   * ksu.exec(cmd, argsJson, callbackName) — callback receives (exitCode, stdout, stderr)
   */
  function execCmd(cmd: string): Promise<{ code: number; stdout: string; stderr: string }> {
    return new Promise((resolve) => {
      const cb = 'cb_' + Date.now() + '_' + (Math.random() * 10000 | 0);
      (window as any)[cb] = (code: number, stdout: string, stderr: string) => {
        delete (window as any)[cb];
        resolve({ code, stdout: stdout || '', stderr: stderr || '' });
      };
      ksu.exec(cmd, '{}', cb);
    });
  }

  function disableButtons() {
    const buttons = document.querySelectorAll('.action-btn') as NodeListOf<HTMLButtonElement>;
    buttons.forEach((b) => {
      b.disabled = true;
      const spinner = b.querySelector('.spinner') as HTMLElement;
      const text = b.querySelector('.btn-text') as HTMLElement;
      if (spinner) spinner.style.display = 'inline-block';
      if (text) text.style.opacity = '0.6';
    });
  }

  function reenableButtons() {
    const buttons = document.querySelectorAll('.action-btn') as NodeListOf<HTMLButtonElement>;
    buttons.forEach((b) => {
      b.disabled = false;
      const spinner = b.querySelector('.spinner') as HTMLElement;
      const text = b.querySelector('.btn-text') as HTMLElement;
      if (spinner) spinner.style.display = 'none';
      if (text) text.style.opacity = '1';
    });
  }

  async function runAction(teeforgeArgs: string, titleKey: string) {
    const dialog = (window as any).__tfDialog;
    const t = (window as any).__tf.t;

    disableButtons();
    dialog.open(t(titleKey));

    try {
      // ksu.exec runs with root, returns all output at once
      const result = await execCmd(TEEFORGE + ' ' + teeforgeArgs);

      if (result.stdout) dialog.appendLog(result.stdout);
      if (result.stderr) dialog.appendLog(result.stderr);

      dialog.done(result.code === 0, result.code);
    } catch (err) {
      dialog.appendLog('\n[error] ' + String(err));
      dialog.done(false, -1);
    }

    reenableButtons();
  }

  document.getElementById('btn-keybox')?.addEventListener('click', () => {
    runAction('--keybox', 'action.keybox.title');
  });

  document.getElementById('btn-target')?.addEventListener('click', () => {
    runAction('--generate', 'action.target.title');
  });
</script>
